# La Cour de la Semeuse — Environment Variables
# Copy this file to .env.local and fill in the values.
# Variables prefixed with VITE_ are exposed to the browser bundle.

# Base URL of the deployed site (used in sitemap, canonical links, OG tags)
# VITE_SITE_URL=https://semeuse.netlify.app

# Contact form endpoint (if you add a backend form handler)
# VITE_FORM_ENDPOINT=https://api.example.com/contact

# Analytics (optional)
# VITE_PLAUSIBLE_DOMAIN=semeuse.netlify.app
